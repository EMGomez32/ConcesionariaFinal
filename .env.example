# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno para docker compose (producción).
# Copiá este archivo a ".env" en el servidor y completá los valores.
# El .env NO debe compartirse ni subirse a repositorios públicos.
#
# Generar secretos fuertes:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# ─────────────────────────────────────────────────────────────────────────────

# --- Base de datos ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIAR_por_password_fuerte
POSTGRES_DB=concesionaria

# --- Secretos JWT (deben ser distintos entre sí y largos) ---
JWT_SECRET=CAMBIAR_por_secreto_aleatorio_largo
JWT_REFRESH_SECRET=CAMBIAR_por_OTRO_secreto_aleatorio_largo

# --- CORS / logging ---
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173,https://autenza.nebulant.com.ar
LOG_LEVEL=info

# --- URL pública del frontend (para el link de recuperación de contraseña) ---
APP_URL=https://autenza.nebulant.com.ar

# --- SMTP para envío de emails (OPCIONAL) ---
# Si no lo configurás, la recuperación de contraseña sigue funcionando: el link
# se escribe en los logs del backend (docker compose logs backend) en vez de
# enviarse por email. Completá esto cuando tengas un proveedor (Gmail, SES, Resend...).
# SMTP_HOST=smtp.tuproveedor.com
# SMTP_PORT=587
# SMTP_USER=usuario
# SMTP_PASS=contraseña
# SMTP_FROM=no-reply@autenza.com.ar

# --- Retención de backups (días) ---
BACKUP_RETENTION_DAYS=14

# ─────────────────────────────────────────────────────────────────────────────
# Bootstrap del admin inicial (SOLO se usa al correr el seed manualmente
# la primera vez; ver README). Si no vas a correr el seed, podés dejarlas vacías.
# ─────────────────────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@tuconcesionaria.com
SEED_ADMIN_PASSWORD=CAMBIAR_por_password_fuerte_min_10
SEED_ADMIN_NOMBRE=Administrador
SEED_CONCESIONARIA_NOMBRE=Mi Concesionaria
SEED_CONCESIONARIA_CUIT=
SEED_CONCESIONARIA_EMAIL=
SEED_SUCURSAL_NOMBRE=Casa Central
